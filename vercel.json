{
        "buildCommand": "npm install --prefix frontend --legacy-peer-deps && npm run build --prefix frontend",
        "outputDirectory": "frontend/build",
        "installCommand": "npm install",
        "routes": [
                {
                        "src": "/api/(.*)",
                        "dest": "/api"
                },
                {
                        "src": "/(.*)",
                        "dest": "/index.html"
                }
        ]
}