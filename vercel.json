{
        "buildCommand": "npm install --prefix frontend --legacy-peer-deps && npm run build --prefix frontend",
        "outputDirectory": "frontend/build",
        "installCommand": "npm install",
        "routes": [
                {
                        "src": "/static/(.*)",
                        "dest": "/static/$1"
                },
                {
                        "src": "/manifest.json",
                        "dest": "/manifest.json"
                },
                {
                        "src": "/favicon.ico",
                        "dest": "/favicon.ico"
                },
                {
                        "src": "/(.*)",
                        "dest": "/index.html"
                }
        ]
}