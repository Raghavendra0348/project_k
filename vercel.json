{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/build",
  "installCommand": "cd frontend && npm install",
  "framework": null,
  "functions": {
    "frontend/api/*.js": {
      "runtime": "@vercel/node@3.0.0"
    }
  },
  "rewrites": [
    {
      "source": "/api/createOrder",
      "destination": "/frontend/api/createOrder.js"
    },
    {
      "source": "/api/verifyPayment",
      "destination": "/frontend/api/verifyPayment.js"
    },
    {
      "source": "/api/products",
      "destination": "/frontend/api/products.js"
    },
    {
      "source": "/api/machines",
      "destination": "/frontend/api/machines.js"
    },
    {
      "source": "/api/alerts",
      "destination": "/frontend/api/alerts.js"
    },
    {
      "source": "/api/lowstock",
      "destination": "/frontend/api/lowstock.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}