{
        "buildCommand": "cd frontend && npm install && npm run build",
        "outputDirectory": "frontend/build",
        "installCommand": "true",
        "api": {
                "baseUrl": "/api"
        },
        "routes": [
                {
                        "src": "/api/(.*)",
                        "methods": [
                                "GET",
                                "POST",
                                "PUT",
                                "DELETE",
                                "OPTIONS"
                        ],
                        "dest": "/api/[...slug]?slug=$1"
                },
                {
                        "src": "/(.*)",
                        "dest": "/index.html"
                }
        ]
}