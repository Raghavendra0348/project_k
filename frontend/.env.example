# Firebase Configuration
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id

# Razorpay Public Key (Safe to expose - this is NOT the secret key)
REACT_APP_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx

# Backend API URL
# For local development with emulator: http://localhost:5001/your-project/asia-south1/api
# For production: https://asia-south1-your-project.cloudfunctions.net/api
REACT_APP_API_BASE_URL=http://localhost:5001/your-project/asia-south1/api

# Environment
REACT_APP_ENV=development
