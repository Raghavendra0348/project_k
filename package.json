{
        "name": "vending-machine-monorepo",
        "version": "1.0.0",
        "description": "QR-based Real-Time Vending Machine System",
        "private": true,
        "scripts": {
                "install:all": "npm install && cd frontend && npm install && cd ../functions && npm install",
                "dev": "concurrently \"cd functions && npm run serve\" \"cd frontend && npm start\"",
                "build": "cd frontend && npm run build && cd ../functions && npm run build",
                "deploy": "npm run build && firebase deploy",
                "deploy:functions": "cd functions && npm run deploy",
                "deploy:hosting": "cd frontend && npm run build && firebase deploy --only hosting",
                "deploy:rules": "firebase deploy --only firestore:rules",
                "emulators": "firebase emulators:start",
                "seed": "cd functions && npm run seed"
        },
        "devDependencies": {
                "concurrently": "^8.2.2"
        },
        "repository": {
                "type": "git",
                "url": "https://github.com/yourusername/vending-machine"
        },
        "keywords": [
                "vending-machine",
                "qr-code",
                "firebase",
                "razorpay",
                "react",
                "real-time"
        ],
        "author": "Your Name",
        "license": "MIT",
        "dependencies": {
                "animejs": "^4.3.6",
                "qr-scanner": "^1.4.2"
        }
}
