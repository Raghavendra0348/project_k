{
        "firestore": {
                "rules": "firestore.rules",
                "indexes": "firestore.indexes.json"
        },
        "functions": {
                "source": "functions",
                "runtime": "nodejs20"
        },
        "hosting": {
                "public": "frontend/build",
                "ignore": [
                        "firebase.json",
                        "**/.*",
                        "**/node_modules/**"
                ],
                "rewrites": [
                        {
                                "source": "**",
                                "destination": "/index.html"
                        }
                ],
                "headers": [
                        {
                                "source": "**/*.@(js|css)",
                                "headers": [
                                        {
                                                "key": "Cache-Control",
                                                "value": "public, max-age=31536000, immutable"
                                        }
                                ]
                        },
                        {
                                "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|ico)",
                                "headers": [
                                        {
                                                "key": "Cache-Control",
                                                "value": "public, max-age=31536000, immutable"
                                        }
                                ]
                        }
                ]
        },
        "emulators": {
                "functions": {
                        "port": 5001,
                        "host": "0.0.0.0"
                },
                "firestore": {
                        "port": 8080,
                        "host": "0.0.0.0"
                },
                "hosting": {
                        "port": 5000
                },
                "ui": {
                        "enabled": false
                }
        }
}